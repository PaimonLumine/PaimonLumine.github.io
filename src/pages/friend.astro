---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('posts');
const friendPost = posts.find((p) => p.data.labels.includes('Friend'));

let Content = null;
if (friendPost) {
  const rendered = await render(friendPost);
  Content = rendered.Content;
}
---

<BaseLayout title="友鄰" description="友鄰">
  <article class="mx-auto max-w-3xl px-4 py-8">
    <h1 class="mb-8 font-[var(--font-title)] text-3xl text-[var(--color-paper)]">友鄰</h1>
    {Content ? (
      <div class="prose">
        <Content />
      </div>
    ) : (
      <p class="text-[var(--color-paper-dim)]">No content yet.</p>
    )}
  </article>
</BaseLayout>
